{
  "name": "ai-sales-calling-agent",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev -w apps/api\" \"npm:dev -w apps/web\"",
    "build": "npm run build -w apps/api && npm run build -w apps/web",
    "lint": "npm run lint -w apps/api && npm run lint -w apps/web",
    "db:migrate": "npm run prisma:migrate -w apps/api",
    "db:push": "npm run prisma:push -w apps/api",
    "db:seed": "npm run seed -w apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
