NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/ai_sales_agent
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-long-random-secret
APP_ENCRYPTION_KEY=replace-with-32-byte-base64-key
API_PORT=4000
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
PUBLIC_API_BASE_URL=

# Real telephony. Exotel is India-first live dialing.
TELEPHONY_PROVIDER=exotel
BILLING_MODE=free
PAYMENT_PROVIDER=disabled

# Demo model. Use a free OpenRouter model for testing.
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Real integrations can be added later.
EXOTEL_REGION=mumbai
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_ACCOUNT_SID=
EXOTEL_CALLER_ID=
# Optional for local testing. Use your Exotel virtual number in production.
EXOTEL_FLOW_URL=
EXOTEL_APP_ID=
EXOTEL_AGENT_NUMBER=
EXOTEL_RECORD=true
EXOTEL_STATUS_CALLBACK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TWIML_URL=
TWILIO_RECORD=false
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=
PLIVO_ANSWER_URL=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=

S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ai-sales-agent
