NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_sales_agent
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-long-random-secret
APP_ENCRYPTION_KEY=replace-with-32-byte-base64-key
API_PORT=4000
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# Demo model. Use a free OpenRouter model for testing.
LLM_PROVIDER=demo
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Real integrations can be added later.
EXOTEL_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=

S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ai-sales-agent
